# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Momence OAuth2 credentials
# Get these from your Momence dashboard → Settings → API
MOMENCE_CLIENT_ID=your_client_id_here
MOMENCE_CLIENT_SECRET=your_client_secret_here

# The widget's origin — used for CORS (your website URL)
WIDGET_ORIGIN=https://www.rbwdenver.com

# Port for local development
PORT=3001
